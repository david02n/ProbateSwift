NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Replace with long random values in Railway.
SESSION_SECRET=replace-with-a-32-plus-character-secret
COOKIE_SECRET=replace-with-a-32-plus-character-secret

# Update this after you attach your Railway/custom domain.
ALLOWED_ORIGINS=https://your-app.up.railway.app,https://probateswift.com,https://www.probateswift.com

# For Railway Postgres, use the injected DATABASE_URL from the attached Postgres service.
DATABASE_URL=postgresql://user:password@host:5432/database

# Mount a Railway volume at /app/uploads if you need file persistence.
UPLOAD_DIR=/app/uploads

# Clerk authentication
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# Stripe payments (Phase C) — the £295 flat fee, charged at submission.
# Checkout uses a hosted Stripe Payment Link, so NO secret API key is required.
#
# STRIPE_PAYMENT_LINK: the buy.stripe.com/… link (a default is baked in; override here).
#   In the Stripe dashboard for this link, set the post-payment redirect to:
#   https://probateswift.com/dashboard?payment=success  (Stripe appends &session_id=…)
# STRIPE_WEBHOOK_SECRET: whsec_… for the /api/webhooks/stripe endpoint. REQUIRED so a
#   completed payment flips the case to 'paid' and unlocks form generation.
# STRIPE_SECRET_KEY: optional — only needed if you switch back to the Checkout Session API.
# PROBATE_FEE_PENCE: fee in minor units used for our own records (29500 = £295).
STRIPE_PAYMENT_LINK=
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
PROBATE_FEE_PENCE=29500

# Used to build form/return URLs (defaults to the request host).
APP_BASE_URL=
